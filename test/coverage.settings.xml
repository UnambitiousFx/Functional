<?xml version="1.0" encoding="utf-8"?>
<Configuration>
    <CodeCoverage>
        <!--
        About include/exclude lists:
        Empty "Include" clauses imply all; empty "Exclude" clauses imply none.
        Each element is a regular expression (ECMAScript syntax).
        An item must first match the include list to be included, then must not match
        the exclude list to remain included.
        -->

        <!-- Exclude the assertion helper assembly and test assemblies from coverage -->
        <!-- (equivalent to the previous Coverlet "[*.Tests]*,[*.xunit]*,[xunit.*]*" exclude) -->
        <ModulePaths>
            <Exclude>
                <ModulePath>.*\.Tests\.dll$</ModulePath>
                <ModulePath>.*\.xunit\.dll$</ModulePath>
                <ModulePath>.*xunit.*\.dll$</ModulePath>
            </Exclude>
        </ModulePaths>

        <!-- Match attributes on any code element -->
        <!-- (equivalent to the previous Coverlet ExcludeByAttribute="Obsolete,GeneratedCode,CompilerGenerated") -->
        <Attributes>
            <Exclude>
                <Attribute>^System\.ObsoleteAttribute$</Attribute>
                <Attribute>^System\.CodeDom\.Compiler\.GeneratedCodeAttribute$</Attribute>
                <Attribute>^System\.Runtime\.CompilerServices\.CompilerGeneratedAttribute$</Attribute>
            </Exclude>
        </Attributes>
    </CodeCoverage>
</Configuration>
