{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "before 4am on monday"
  ],
  "prConcurrentLimit": 10,
  "packageRules": [
    {
      "matchManagers": ["nuget"],
      "matchPackageNames": ["Microsoft.**"],
      "groupName": "microsoft"
    },
    {
      "matchManagers": ["nuget"],
      "matchPackageNames": ["BenchmarkDotNet**"],
      "groupName": "benchmarkdotnet"
    },
    {
      "matchManagers": ["nuget"],
      "matchPackageNames": ["xunit**", "NSubstitute**", "coverlet**"],
      "groupName": "testing"
    },
    {
      "matchManagers": ["npm"],
      "matchFileNames": ["docs/**"],
      "groupName": "docs"
    }
  ]
}
