{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "before 4am on monday"
  ],
  "prConcurrentLimit": 10,
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "matchManagers": ["nuget"],
      "matchPackageNames": ["Microsoft.**"],
      "groupName": "microsoft"
    },
    {
      "matchManagers": ["nuget"],
      "matchPackageNames": ["BenchmarkDotNet**"],
      "groupName": "benchmarkdotnet"
    },
    {
      "matchManagers": ["nuget"],
      "matchPackageNames": ["xunit**", "NSubstitute**", "coverlet**"],
      "groupName": "testing"
    },
    {
      "matchManagers": ["npm"],
      "matchFileNames": ["docs/**"],
      "groupName": "docs"
    },
    {
      "description": "Keep ASP.NET Core test host on net8 line",
      "matchManagers": ["nuget"],
      "matchPackageNames": ["Microsoft.AspNetCore.Mvc.Testing"],
      "matchCurrentVersion": "/^8\\./",
      "allowedVersions": "<9.0.0"
    },
    {
      "description": "Keep ASP.NET Core test host on net9 line",
      "matchManagers": ["nuget"],
      "matchPackageNames": ["Microsoft.AspNetCore.Mvc.Testing"],
      "matchCurrentVersion": "/^9\\./",
      "allowedVersions": "<10.0.0"
    }
  ]
}
